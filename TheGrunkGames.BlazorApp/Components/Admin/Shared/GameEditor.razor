<div class="card mb-2">
    <div class="card-body d-flex align-items-center gap-3">
        <div class="flex-grow-1">
            <label class="form-label mb-1">Name</label>
            <input type="text" class="form-control form-control-sm" @bind="Game.Name" />
        </div>
        <div>
            <label class="form-label mb-1">Device</label>
            <select class="form-select form-select-sm" @bind="Game.Device">
                @foreach (var device in Enum.GetValues<Device>())
                {
                    <option value="@device">@device</option>
                }
            </select>
        </div>
        <div class="pt-4">
            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="OnRemove" title="Remove">✕</button>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Game Game { get; set; } = default!;
    [Parameter] public EventCallback OnRemove { get; set; }
}

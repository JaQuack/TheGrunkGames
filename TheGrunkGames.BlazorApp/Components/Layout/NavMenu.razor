<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">TheGrunkGames</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="standings">
                <span class="bi bi-trophy-fill" aria-hidden="true"></span> Standings
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="stats">
                <span class="bi bi-graph-up" aria-hidden="true"></span> Team Stats
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="history">
                <span class="bi bi-clock-history" aria-hidden="true"></span> History
            </NavLink>
        </div>

        <AuthorizeView Policy="Admin">
            <Authorized>
                <div class="nav-item px-3 mt-3">
                    <span class="text-uppercase small fw-bold" style="color: white;">Admin</span>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/tournament">
                        Tournament Settings
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/teams">
                        Teams
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/games">
                        Games
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/rounds">
                        Rounds &amp; Matches
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/standings">
                        Standings
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/stats">
                        Team Stats
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/history">
                        History
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/archive">
                        Archive Tournament
                    </NavLink>
                </div>
                <div class="nav-item px-3 mt-2">
                    <a class="nav-link text-muted" href="/auth/logout">Sign out (@context.User.FindFirst("email")?.Value)</a>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3 mt-3">
                    <a class="nav-link" href="/auth/login">
                        🔑 Admin Sign In
                    </a>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>


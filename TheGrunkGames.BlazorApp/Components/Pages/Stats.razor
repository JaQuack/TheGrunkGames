@page "/stats"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject GameServiceClient gameServiceClient
@inject TournamentHubConnection hubConnection

<div class="stats-page">
    <div class="page-header">
        <h1>📊 Team Stats</h1>
    </div>

    @if (TeamStats is not null && TeamStats.Count > 0)
    {
        <div class="stats-grid">
            @foreach (var team in TeamStats)
            {
                <div class="team-stats-card">
                    <div class="card-header">@team.TeamName</div>
                    <div class="card-body">
                        @if (team.PlayedAgainstTeam.Count > 0)
                        {
                            <h6>Opponents</h6>
                            <table class="stats-table">
                                <thead>
                                    <tr>
                                        <th>Team</th>
                                        <th>Played</th>
                                        <th>W</th>
                                        <th>D</th>
                                        <th>L</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var opp in team.PlayedAgainstTeam)
                                    {
                                        <tr>
                                            <td>@opp.Name</td>
                                            <td>@opp.TimesPlayed</td>
                                            <td class="win">@opp.Wins</td>
                                            <td class="draw">@opp.Draws</td>
                                            <td class="loss">@opp.Losses</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }

                        @if (team.PlayedGames.Count > 0)
                        {
                            <h6>Games Played</h6>
                            <table class="stats-table">
                                <thead>
                                    <tr>
                                        <th>Game</th>
                                        <th>Times</th>
                                        <th>Results</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var game in team.PlayedGames)
                                    {
                                        <tr>
                                            <td>@game.Name</td>
                                            <td>@game.TimesPlayed</td>
                                            <td class="game-results">
                                                @for (var r = 0; r < game.Results.Count; r++)
                                                {
                                                    @if (r > 0) { <span class="result-sep">,</span> }
                                                    <span class="@($"result-{char.ToLower(game.Results[r])}")">
                                                        @game.Results[r]
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }

                        @if (team.PlayedAgainstTeam.Count == 0 && team.PlayedGames.Count == 0)
                        {
                            <p class="no-matches">No matches played yet.</p>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="no-data">No team stats available.</p>
    }
</div>

@code {
    private List<TheGrunkGames.Models.TournamentModels.TeamStats>? TeamStats;

    protected override async Task OnInitializedAsync()
    {
        hubConnection.OnTournamentUpdated += OnTournamentUpdated;
        await hubConnection.StartAsync();
        await LoadData();
    }

    private void OnTournamentUpdated()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        });
    }

    private async Task LoadData()
    {
        var result = await gameServiceClient.GetTeamStats();
        TeamStats = result.Success ? result.Data : null;
    }

    public async ValueTask DisposeAsync()
    {
        hubConnection.OnTournamentUpdated -= OnTournamentUpdated;
    }
}
